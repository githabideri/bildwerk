{
  "name": "vedute_sketch_to_photo",
  "description": "Convert historical town sketches to photorealistic modern views",
  "preset": "vedute",
  "comfyui_workflow": {
    "3": {
      "inputs": {
        "seed": 42,
        "steps": 20,
        "cfg": 7.5,
        "sampler_name": "euler_ancestral",
        "scheduler": "normal",
        "denoise": 1.0,
        "model": ["4", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["8", 0]
      },
      "class_type": "KSampler",
      "_meta": {
        "title": "KSampler"
      }
    },
    "4": {
      "inputs": {
        "ckpt_name": "sd_xl_base_1.0.safetensors"
      },
      "class_type": "CheckpointLoaderSimple",
      "_meta": {
        "title": "Load Checkpoint"
      }
    },
    "5": {
      "inputs": {
        "filename": "input_sketch.jpg",
        "upload": "image"
      },
      "class_type": "LoadImage",
      "_meta": {
        "title": "Load Image"
      }
    },
    "6": {
      "inputs": {
        "text": "photorealistic modern city view, high quality, detailed architecture, natural lighting, 8k, professional photography",
        "clip": ["4", 1]
      },
      "class_type": "CLIPTextEncode",
      "_meta": {
        "title": "CLIP Text Encode (Positive)"
      }
    },
    "7": {
      "inputs": {
        "text": "sketch, drawing, pencil, lines, unfinished, low quality, blurry, distorted, text, watermark, signature",
        "clip": ["4", 1]
      },
      "class_type": "CLIPTextEncode",
      "_meta": {
        "title": "CLIP Text Encode (Negative)"
      }
    },
    "8": {
      "inputs": {
        "pixels": ["12", 0]
      },
      "class_type": "VAEDecode",
      "_meta": {
        "title": "VAE Decode"
      }
    },
    "9": {
      "inputs": {
        "filename_prefix": "bildwerk_output",
        "images": [
          ["3", 0]
        ]
      },
      "class_type": "SaveImage",
      "_meta": {
        "title": "Save Image"
      }
    },
    "10": {
      "inputs": {
        "control_net_name": "controlnet-sdxl-softedge-anime.safetensors",
        "checkpoint": ["4", 0]
      },
      "class_type": "ControlNetLoader",
      "_meta": {
        "title": "ControlNet Loader (SoftEdge)"
      }
    },
    "11": {
      "inputs": {
        "control_net": ["10", 0],
        "image": ["5", 0],
        "strength": 0.8,
        "start_percent": 0.0,
        "end_percent": 1.0
      },
      "class_type": "ControlNetApply",
      "_meta": {
        "title": "Apply ControlNet (SoftEdge)"
      }
    },
    "12": {
      "inputs": {
        "samples": ["11", 0]
      },
      "class_type": "VAEEncode",
      "_meta": {
        "title": "VAE Encode"
      }
    }
  },
  "parameters": {
    "steps": 20,
    "cfg_scale": 7.5,
    "sampler": "euler_ancestral",
    "scheduler": "normal",
    "seed": -1,
    "width": 1024,
    "height": 768
  },
  "controlnet_config": {
    "primary": {
      "model": "controlnet-sdxl-softedge",
      "weight": 0.8,
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },
  "prompts": {
    "positive": "photorealistic modern city view, high quality, detailed architecture, natural lighting, 8k, professional photography",
    "negative": "sketch, drawing, pencil, lines, unfinished, low quality, blurry, distorted, text, watermark, signature"
  }
}
