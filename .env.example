# Bildwerk Router Environment Variables
# Copy this file to .env and customize for your deployment
# DO NOT commit .env files with real credentials to version control

# =============================================================================
# Nextcloud Configuration
# =============================================================================

# Nextcloud/WebDAV base URL (e.g., https://cloud.example.com)
BILDWORK_NEXTCLOUD_URL=https://your-nextcloud-instance.com

# Nextcloud service account username
BILDWORK_NEXTCLOUD_USERNAME=bildwerk-service

# Nextcloud service account password (or use BILDWORK_NEXTCLOUD_SECRETS_FILE)
# BILDWORK_NEXTCLOUD_PASSWORD=your-password-here

# Path to file containing Nextcloud password (alternative to BILDWORK_NEXTCLOUD_PASSWORD)
# BILDWORK_NEXTCLOUD_SECRETS_FILE=/path/to/secrets/nextcloud.yaml

# Nextcloud folder paths (relative to user's root in Nextcloud)
BILDWORK_NEXTCLOUD_BASE_FOLDER=bildwerk
BILDWORK_NEXTCLOUD_INBOX=inbox
BILDWORK_NEXTCLOUD_PROCESSING=processing
BILDWORK_NEXTCLOUD_DONE=done
BILDWORK_NEXTCLOUD_ERROR=error
BILDWORK_NEXTCLOUD_REVIEW=review

# =============================================================================
# Worker Configuration
# =============================================================================

# ComfyUI worker URL (e.g., http://192.168.1.100:8188)
BILDWORK_WORKER_URL=http://your-worker-ip:8188

# Worker name for logging
BILDWORK_WORKER_NAME=gpu-worker

# =============================================================================
# Classification Configuration
# =============================================================================

# Base directory for classification files (manifest, overrides)
BILDWORK_CLASSIFICATION_DIR=classification

# Manifest file name (relative to BILDWORK_CLASSIFICATION_DIR)
BILDWORK_MANIFEST_FILE=manifest.corrected.json

# Overrides file name (relative to BILDWORK_CLASSIFICATION_DIR)
BILDWORK_OVERRIDES_FILE=overrides.json

# =============================================================================
# Router Configuration
# =============================================================================

# Router config file path
BILDWORK_CONFIG=/path/to/router/config.yaml

# Temp directory for processing
BILDWORK_TEMP_DIR=/tmp/bildwerk/router

# Staging directory
BILDWORK_STAGING_DIR=/tmp/bildwerk/staging

# =============================================================================
# Presets Configuration
# =============================================================================

# Path to presets directory
BILDWORK_PRESETS_DIR=/path/to/presets

# =============================================================================
# Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
BILDWORK_LOG_LEVEL=INFO

# Log format: json, text
BILDWORK_LOG_FORMAT=json
